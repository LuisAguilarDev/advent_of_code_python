      "updated": 1772334284813,
      "link": null,
      "locked": false,
      "text": "4) Prueba desordenada\n(1518-11-01 00:25) wakes up\n(1518-11-01 00:00) Guard #10 begins shift\n(1518-11-01 00:05) falls asleep\n\nTras ordenar:\n(1518-11-01 00:00) Guard #10 begins shift\n(1518-11-01 00:05) falls asleep\n(1518-11-01 00:25) wakes up\n\nnaps: {10: [(5, 24)]}\n  Siesta 1: min 5, 6, 7, ..., 24\n  Todos freq 1 → most_common devuelve 5\n\nguard = 10, minute = 5\n10 * 5 = 50\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4) Prueba desordenada\n(1518-11-01 00:25) wakes up\n(1518-11-01 00:00) Guard #10 begins shift\n(1518-11-01 00:05) falls asleep\n\nTras ordenar:\n(1518-11-01 00:00) Guard #10 begins shift\n(1518-11-01 00:05) falls asleep\n(1518-11-01 00:25) wakes up\n\nnaps: {10: [(5, 24)]}\n  Siesta 1: min 5, 6, 7, ..., 24\n  Todos freq 1 → most_common devuelve 5\n\nguard = 10, minute = 5\n10 * 5 = 50\n",
      "autoResize": true,
      "lineHeight": 1.25
