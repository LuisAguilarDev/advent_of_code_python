      "isDeleted": false,
      "boundElements": null,
      "updated": 1772334256052,
      "link": null,
      "locked": false,
      "text": "3) Dos guardias quien duerme mas\n(1518-11-01 00:00) Guard #10 begins shift\n(1518-11-01 00:10) falls asleep\n(1518-11-01 00:40) wakes up\n(1518-11-02 00:00) Guard #99 begins shift\n(1518-11-02 00:05) falls asleep\n(1518-11-02 00:10) wakes up\n\nnaps: {10: [(10, 39)], 99: [(5, 9)]}\nGuard 10: 30 min totales\nGuard 99: 5 min totales\nGuard 10 gana por más tiempo dormido\n\nguard = 10",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3) Dos guardias quien duerme mas\n(1518-11-01 00:00) Guard #10 begins shift\n(1518-11-01 00:10) falls asleep\n(1518-11-01 00:40) wakes up\n(1518-11-02 00:00) Guard #99 begins shift\n(1518-11-02 00:05) falls asleep\n(1518-11-02 00:10) wakes up\n\nnaps: {10: [(10, 39)], 99: [(5, 9)]}\nGuard 10: 30 min totales\nGuard 99: 5 min totales\nGuard 10 gana por más tiempo dormido\n\nguard = 10",
      "autoResize": true,
      "lineHeight": 1.25
    },
