    {
      "id": "IB8bHo8bTBclVJ43OStf2",
      "type": "text",
      "x": -1475.1387172899185,
      "y": 9465.968090888813,
      "width": 472.2875671386719,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
