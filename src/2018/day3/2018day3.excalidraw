      "groupIds": [],
      "frameId": null,
      "index": "bM1",
      "roundness": null,
      "seed": 1990580573,
      "version": 277,
      "versionNonce": 1958769245,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769875315150,
      "link": null,
      "locked": false,
      "text": "Dentro del caos te das cuenta que una afirmacion no se\nsolapa con ninguna otra, si pudieras atraer la atencion a\nese pedazo de tela tal vez los elfos hagan el traje despues\nde todo\n\ncual es el id del pedazo que no solapa con ninguna afirmacion",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Dentro del caos te das cuenta que una afirmacion no se\nsolapa con ninguna otra, si pudieras atraer la atencion a\nese pedazo de tela tal vez los elfos hagan el traje despues\nde todo\n\ncual es el id del pedazo que no solapa con ninguna afirmacion",
      "autoResize": true,
      "lineHeight": 1.25
    },
