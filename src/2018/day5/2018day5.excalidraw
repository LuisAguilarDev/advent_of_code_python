    {
      "id": "_1uS3aE7tWJUk7H24BRIY",
      "type": "text",
      "x": -2245.578692815957,
      "y": 10211.19861797157,
      "width": 539.9674682617188,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "c0Kk",
      "roundness": null,
      "seed": 1958905390,
      "version": 979,
      "versionNonce": 260970437,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772961572684,
      "link": null,
      "locked": false,
      "text": "recorremos cada unidad del polimero\nCaso 1 pila vacia\nno hay con quien comparar se agrega a la pila\nCaso 2 pila con unidades\nSe compara la unidad actual con la del tope de la pila\n    caso a) son la misma unidad de diferente polaridad (se destruyen)\n                -Se elimina la del tope del stack stack.pop()\n                -Continuo al siguiente caracter el actual se descarta\n    caso b) son diferentes unidades o misma polaridad (No reacciona)\n                 -Se agrega al tope del stack\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "recorremos cada unidad del polimero\nCaso 1 pila vacia\nno hay con quien comparar se agrega a la pila\nCaso 2 pila con unidades\nSe compara la unidad actual con la del tope de la pila\n    caso a) son la misma unidad de diferente polaridad (se destruyen)\n                -Se elimina la del tope del stack stack.pop()\n                -Continuo al siguiente caracter el actual se descarta\n    caso b) son diferentes unidades o misma polaridad (No reacciona)\n                 -Se agrega al tope del stack\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
